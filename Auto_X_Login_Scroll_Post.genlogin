        {
          "type": "custom",
          "data": {
            "icon": "actionScript",
            "action": "Script",
            "options": {
              "disabled": false,
              "nodeTimeout": "120",
              "timeoutNextNode": "successNode",
              "breakpoint": false,
              "code": "// Scroll explore in 5 minutes\nconst endTime = Date.now() + 5 * 60 * 1000;\nwhile (Date.now() < endTime) {\n    await page.evaluate(() => window.scrollBy(0, window.innerHeight));\n    await new Promise(r => setTimeout(r, 2000 + Math.random() * 3000));\n    if (Math.random() < 0.3) {\n        const like = await page.$('[data-testid=\"like\"]');\n        if (like) { await like.click(); await new Promise(r => setTimeout(r, 1000)); }\n    }\n}\n"
            },
            "successNode": null,
            "failNode": null
          },
          "events": {},
          "id": "2NsJt",
          "position": {
            "x": 660,
            "y": 1340
          },
          "label": "Run Script",
          "sourcePosition": "right",
          "targetPosition": "left",
          "class": ""
        },
        {
          "type": "custom",
          "data": {
            "icon": "actionScript",
            "action": "Script",
            "options": {
              "disabled": false,
              "nodeTimeout": "120",
              "timeoutNextNode": "successNode",
              "breakpoint": false,
              "code": "\n// Read RSS feed and store items\nconst res = await fetch('${RSS_FEED}');\nconst text = await res.text();\nconst items = [];\nconst matches = text.match(/<item>[\\s\\S]*?<\\/item>/g) || [];\nfor (const item of matches) {\n    const title = (item.match(/<title>(.*?)<\\/title>/) || [])[1] || '';\n    const link = (item.match(/<link>(.*?)<\\/link>/) || [])[1] || '';\n    if (title && link) items.push({title, link});\n}\n// Store in variable\nglobalThis.rssItems = items;\nconsole.log('Found ' + items.length + ' RSS items');\n"
            },
            "successNode": null,
            "failNode": null
          },
          "events": {},
          "id": "9XvS0",
          "position": {
            "x": 660,
            "y": 1450
          },
          "label": "Run Script",
          "sourcePosition": "right",
          "targetPosition": "left",
          "class": ""
