              "loopType": "For",
              "forFrom": "1",
              "forTo": "${MAX_POSTS}",
              "forEachFrom": "",
              "forEachValue": "",
              "whileLeftOperand": "",
              "whileOperator": null,
              "whileRightperand": ""
            },
