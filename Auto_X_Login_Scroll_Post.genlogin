          "id": "QgJaO",
          "position": {
            "x": 1040,
            "y": 200
          },
          "label": "Loop",
          "sourcePosition": "right",
          "targetPosition": "left",
          "style": {
            "width": "120px",
            "height": "120px",
            "backgroundColor": "#55b3e6",
            "color": "#fff",
            "box-shadow": "#83c3e6 0px 0px 12px",
            "--vf-node-color": "#d03a52",
            "--vf-handle": "#62fcaf",
            "border-radius": "50%"
          },
          "class": ""
        },
        {
          "type": "custom",
          "data": {
            "icon": "actionScript",
            "action": "Script",
            "options": {
              "disabled": false,
              "nodeTimeout": "120",
              "timeoutNextNode": "successNode",
              "breakpoint": false,
              "code": "\n// Post current RSS item\nconst itemIndex = (typeof loopIndex !== 'undefined') ? loopIndex - 1 : 0;\nconst items = globalThis.rssItems || [];\nif (itemIndex >= items.length) {\n    console.log('No more items');\n    return;\n}\nconst item = items[itemIndex];\nconsole.log('Posting: ' + item.title);\n\nawait page.goto('https://x.com/compose/post', { waitUntil: 'networkidle2' });\nawait new Promise(r => setTimeout(r, 2000));\n\nlet tweet = item.title + '\\n\\n' + item.link;\nif (tweet.length > 280) tweet = tweet.substring(0, 277) + '...';\n\nconst ta = await page.$('[data-testid=\"tweetTextarea_0\"]');\nif (ta) {\n    await ta.click();\n    await page.keyboard.type(tweet, { delay: 30 });\n    await new Promise(r => setTimeout(r, 2000));\n    const btn = await page.$('[data-testid=\"tweetButtonInline\"]');\n    if (btn) {\n        await btn.click();\n        console.log('Posted: ' + item.title);\n    }\n}\n"
            },
            "successNode": null,
            "failNode": null
          },
